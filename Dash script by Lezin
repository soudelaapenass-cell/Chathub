PathVisualFolder.Parent = workspace

local TpTargetPart = Instance.new("Part")
TpTargetPart.Shape = Enum.PartType.Ball
TpTargetPart.Size = Vector3.new(3, 3, 3)
TpTargetPart.Color = Color3.fromRGB(255, 0, 0)
TpTargetPart.Material = Enum.Material.Neon
TpTargetPart.Transparency = 0.9
TpTargetPart.Anchored = true
TpTargetPart.CanCollide = false

local function ClearPath()
    PathVisualFolder:ClearAllChildren()
    CurrentPathWaypoints = {}
end

local function DrawPath(waypoints)
    ClearPath()
    CurrentPathWaypoints = waypoints
    for i = 1, #waypoints - 1 do
        local p1 = waypoints[i].Position
        local p2 = waypoints[i+1].Position
        local dist = (p1 - p2).Magnitude
        
        local line = Instance.new("Part")
        line.Size = Vector3.new(0.3, 0.3, dist)
        line.CFrame = CFrame.lookAt(p1, p2) * CFrame.new(0, 0, -dist/2)
        line.Anchored = true
        line.CanCollide = false
        line.Material = Enum.Material.Neon
        line.Color = Color3.fromRGB(0, 200, 255)
        line.Transparency = 0.4
        line.Parent = PathVisualFolder
    end
end

-- Captura de Cliques na Tela para os Novos Modos
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if Config.Mode == "Teleport" then
            TpTargetPart.Position = Mouse.Hit.Position
            TpTargetPart.Parent = workspace
        elseif Config.Mode == "Click" then
            local Char = Player.Character
            local HRP = Char and Char:FindFirstChild("HumanoidRootPart")
            if HRP then
                local path = PathfindingService:CreatePath({
                    AgentRadius = 2,
                    AgentHeight = 5,
                    AgentCanJump = true
                })
                path:ComputeAsync(HRP.Position, Mouse.Hit.Position)
                if path.Status == Enum.PathStatus.Success then
                    DrawPath(path:GetWaypoints())
                else
                    ClearPath()
                end
            end
        end
    end
end)

-- Sistema de Impulso
local function ExecuteDash()
    local Char = Player.Character
    local HRP = Char and Char:FindFirstChild("HumanoidRootPart")
    if not HRP then return end
    
    LastDashPosition = HRP.CFrame
    
    if Config.Mode == "Teleport" then
        if TpTargetPart.Parent == workspace then
            HRP.CFrame = CFrame.new(TpTargetPart.Position + Vector3.new(0, 3, 0))
        end
    elseif Config.Mode == "Click" then
        if #CurrentPathWaypoints > 0 then
            task.spawn(function()
                for _, wp in ipairs(CurrentPathWaypoints) do
                    if wp.Action == Enum.PathWaypointAction.Jump then
                        Char.Humanoid.Jump = true
                    end
                    local tween = TweenService:Create(HRP, TweenInfo.new(0.04, Enum.EasingStyle.Linear), {CFrame = CFrame.new(wp.Position + Vector3.new(0,3,0))})
                    tween:Play()
                    tween.Completed:Wait()
                end
                ClearPath()
            end)
        end
    elseif Config.Mode == "Câmera" then
        local Direction = Camera.CFrame.LookVector
        HRP.AssemblyLinearVelocity = Direction * Config.Power
    else
        local Direction = HRP.CFrame.LookVector
        HRP.AssemblyLinearVelocity = Direction * Config.Power
    end
end

