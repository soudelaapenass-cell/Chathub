-- Configurações e Salvamento
local ConfigFile = "ImpulsoConfig_Lezin.json"
local Config = { Power = 500, Mode = "Personagem", Step = 50 }

local function SaveConfig()
    pcall(function()
        writefile(ConfigFile, HttpService:JSONEncode(Config))
    end)
end

local function LoadConfig()
    pcall(function()
        if isfile(ConfigFile) then
            local decoded = HttpService:JSONDecode(readfile(ConfigFile))
            if decoded then
                Config.Power = decoded.Power or Config.Power
                Config.Mode = decoded.Mode or Config.Mode
                Config.Step = decoded.Step or Config.Step
            end
        end
    end)
end
