local IsHoldingMain = false

-- Função para o botão externo segurar
local function SetupExternalHold(btn)
    local IsHoldingExt = false
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            IsHoldingExt = true
            ExecuteDash() -- Dá o primeiro dash instantaneamente
            
            task.spawn(function()
                task.wait(0.3) -- Atraso antes do spam contínuo começar
                while IsHoldingExt do
                    ExecuteDash()
                    task.wait(0.05) -- Velocidade do auto-dash (altere se quiser mais rápido/devagar)
                end
            end)
        end
    end)
    
    btn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            IsHoldingExt = false
        end
    end)
end

-- Lógica do Botão Principal
DashBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        IsHoldingMain = true
        local CurrentTime = tick()
        
        -- Lógica do Duplo Clique
        if CurrentTime - LastClickTime < 0.35 then
            if not ExternalDashBtn then
                ExternalDashBtn = Instance.new("TextButton")
                ExternalDashBtn.Size = UDim2.new(0, 60, 0, 60)
                ExternalDashBtn.Position = UDim2.new(0.8, 0, 0.7, 0)
                ExternalDashBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
                ExternalDashBtn.Text = "⚡"
                ExternalDashBtn.TextSize = 24
                ExternalDashBtn.Parent = ScreenGui
                Instance.new("UICorner", ExternalDashBtn).CornerRadius = UDim.new(1, 0)
                MakeDraggable(ExternalDashBtn)
                
                SetupExternalHold(ExternalDashBtn) -- Aplica a lógica de segurar ao botão externo
            end
        else
            ExecuteDash() -- Dá o primeiro dash
        end
        LastClickTime = CurrentTime
        
        -- Lógica de segurar (Auto-Dash)
        task.spawn(function()
            task.wait(0.3) -- Atraso antes do spam contínuo
            while IsHoldingMain do
                ExecuteDash()
                task.wait(0.05) -- Velocidade do auto-dash principal
            end
        end)
    end
end)

DashBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        IsHoldingMain = false
    end
end)
