local MinPower = 1
local MaxPower = tonumber("9999999999999999999999999999999999999995000000000")

local function UpdatePowerDisplay()
    Config.Power = math.clamp(Config.Power, MinPower, MaxPower)
    local displayStr = string.format("%.0f", Config.Power)
    PowerDisplay.Text = "Força:\n" .. displayStr
    SaveConfig()
end
UpdatePowerDisplay()

local function SetupHoldButton(btn, isPlus)
    local holding = false
    
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            holding = true
            
            Config.Power = Config.Power + (isPlus and Config.Step or -Config.Step)
            UpdatePowerDisplay()
            
            local holdTime = 0
            local delayBeforeRapid = 0.3
            
            while holding do
                task.wait(0.05)
                holdTime = holdTime + 0.05
                
                if holdTime >= delayBeforeRapid then
                    local turboMultiplier = math.floor(holdTime * 3) 
                    local turboStep = Config.Step * turboMultiplier
                    Config.Power = Config.Power + (isPlus and turboStep or -turboStep)
                    UpdatePowerDisplay()
                end
            end
        end
    end)
    
    btn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            holding = false
        end
    end)
end

