        end
    end)
end

local gmt = getrawmetatable(game)
local oldIndex = gmt.__index
local oldNamecall = gmt.__namecall
setreadonly(gmt, false)

gmt.__index = newcclosure(function(self, index)
    if not _G.MagnetAtivado and not (IsEnabled and AimMode == "Silent Aim") then return oldIndex(self, index) end
    if not checkcaller() then
        if self == Mouse then
            if IsEnabled and AimMode == "Silent Aim" and _G.SilentTarget then
                if math.random(1, 100) <= HitChance then
                    if index == "Hit" then 
                        local aimPos = _G.SilentTarget.Position
                        if PREDICT_STRENGTH > 0 then aimPos = aimPos + (_G.SilentTarget.AssemblyLinearVelocity * PREDICT_STRENGTH) end
                        return CFrame.new(aimPos) 
                    end
                    if index == "Target" then return _G.SilentTarget end
                end
            elseif _G.MagnetAtivado then
                if index == "Hit" then return CFrame.new(camera.CFrame.Position + (camera.CFrame.LookVector * 10000)) end
                if index == "Target" then return nil end
            end
        end
    end
    return oldIndex(self, index)
end)

gmt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    if not _G.MagnetAtivado and not (IsEnabled and AimMode == "Silent Aim") then return oldNamecall(self, ...) end

    local args = {...}
    if not checkcaller() then
        local caller = getcallingscript and getcallingscript()
        if caller and string.find(caller.Name, "Camera") then return oldNamecall(self, ...) end

        local redirectPos = nil
        if IsEnabled and AimMode == "Silent Aim" and _G.SilentTarget then
            if math.random(1, 100) <= HitChance then
                redirectPos = _G.SilentTarget.Position
                if PREDICT_STRENGTH > 0 then redirectPos = redirectPos + (_G.SilentTarget.AssemblyLinearVelocity * PREDICT_STRENGTH) end
            end
        elseif _G.MagnetAtivado then
            redirectPos = camera.CFrame.Position + (camera.CFrame.LookVector * 10000)
        end

        if redirectPos then
            if method == "Raycast" then
                local origin = args[1]
                local direction = args[2]
                local mag = direction.Magnitude
                if mag == 0 then mag = 1 end
                args[2] = (redirectPos - origin).Unit * mag
                return oldNamecall(self, unpack(args))
            elseif method == "FindPartOnRay" or method == "FindPartOnRayWithIgnoreList" or method == "FindPartOnRayWithWhitelist" then
                local ray = args[1]
                local mag = ray.Direction.Magnitude
                if mag == 0 then mag = 1 end
                args[1] = Ray.new(ray.Origin, (redirectPos - ray.Origin).Unit * mag)
                return oldNamecall(self, unpack(args))
            end
        end

        if _G.MagnetAtivado and self == UserInputService and method == "GetMouseLocation" then
            return camera.ViewportSize / 2
        end
    end
    return oldNamecall(self, ...)
end)
setreadonly(gmt, true)

-- // LÓGICA CORE AIMBOT //
local cachedTargets = {}
local lastCacheTime = 0

local function getPotentialTargets()
    local validTargets = {}
    
    if tick() - lastCacheTime > 1.0 then
        cachedTargets = {}
        local function scanLevel(parent, depth)
            if depth > 3 then return end
            for _, obj in ipairs(parent:GetChildren()) do
                if obj:IsA("Model") and obj ~= localPlayer.Character then
                    if obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head") or obj:FindFirstChild("Torso") or obj:FindFirstChild("UpperTorso") then
                        table.insert(cachedTargets, obj)
                    else
                        scanLevel(obj, depth + 1)
                    end
                elseif obj:IsA("Folder") then
                    scanLevel(obj, depth + 1)
                end
            end
        end
        
        scanLevel(Workspace, 1)
        lastCacheTime = tick()
    end

    for _, model in ipairs(cachedTargets) do
        if model and model.Parent then
            local isPlr = Players:GetPlayerFromCharacter(model)
            if not isPlr then
                for _, p in ipairs(Players:GetPlayers()) do
                    if p.Name == model.Name or p.DisplayName == model.Name then
                        isPlr = p
                        break
                    end
                end
            end
            
            local isDead = false
            local hum = model:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health <= 0 then isDead = true end
            
            local customHp = model:GetAttribute("Health") or model:GetAttribute("HP")
            if customHp and type(customHp) == "number" and customHp <= 0 then isDead = true end
            
            if not isDead then
                if TargetType == "Players" and isPlr then
                    table.insert(validTargets, model)
                elseif TargetType == "NPCs" and not isPlr then
                    table.insert(validTargets, model)
                elseif TargetType == "Ambos" then
                    table.insert(validTargets, model)
                end
            end
        end
    end
    
    return validTargets
end

local function getFovCenter() 
    return FovPosition == "Center" and Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2) or UserInputService:GetMouseLocation() 
end

local function getCorrectPart(character)
    if not character then return nil end
    local part = character:FindFirstChild(TargetPart)
    if part and part:IsA("BasePart") then return part end
    return character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Head") or character:FindFirstChild("Torso") or character:FindFirstChildWhichIsA("BasePart")
end

local function getClosestPart()
    if not IsEnabled then CurrentTarget = nil; return nil end

    if LockMode == "LockUntilDeath" and CurrentTarget then
        local isDead = false
        local hum = CurrentTarget:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health <= 0 then isDead = true end
        
        local customHp = CurrentTarget:GetAttribute("Health") or CurrentTarget:GetAttribute("HP")
        if customHp and type(customHp) == "number" and customHp <= 0 then isDead = true end

        if not isDead and CurrentTarget.Parent ~= nil then
            return getCorrectPart(CurrentTarget)
        else
            CurrentTarget = nil 
        end
    end
    
    local closest, dist = nil, math.huge
    local fovCenter = getFovCenter()
    local possibleTargets = getPotentialTargets()
    local myRoot = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    for _, obj in ipairs(possibleTargets) do
        local isPlayer = false
        if Players:GetPlayerFromCharacter(obj) then 
            isPlayer = Players:GetPlayerFromCharacter(obj) 
        else
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Name == obj.Name then isPlayer = p; break end
            end
        end

        if TeamCheck and isPlayer and type(isPlayer) ~= "boolean" and isPlayer.Team == localPlayer.Team then continue end
        
        local part = getCorrectPart(obj)
        if part then
            if FocusMode == "1° Pessoa Padrão" then
                local pos, onScreen = camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local mDist = (Vector2.new(pos.X, pos.Y) - fovCenter).Magnitude
                    if mDist <= FovValue and mDist < dist then
                        if WallCheck then
                            local params = RaycastParams.new()
                            params.FilterDescendantsInstances = {localPlayer.Character, obj}
                            params.FilterType = Enum.RaycastFilterType.Blacklist
                            local rayResult = Workspace:Raycast(camera.CFrame.Position, part.Position - camera.CFrame.Position, params)
                            if rayResult then continue end
                        end
                        dist = mDist
                        closest = part
                        CurrentTarget = obj
                    end
                end
            elseif FocusMode == "360" then
                if myRoot then
                    local wDist = (myRoot.Position - part.Position).Magnitude
                    if wDist <= 400 and wDist < dist then
                        if WallCheck then
                            local params = RaycastParams.new()
                            params.FilterDescendantsInstances = {localPlayer.Character, obj}
                            params.FilterType = Enum.RaycastFilterType.Blacklist
                            local rayResult = Workspace:Raycast(camera.CFrame.Position, part.Position - camera.CFrame.Position, params)
                            if rayResult then continue end
                        end
                        dist = wDist
                        closest = part
                        CurrentTarget = obj
                    end
                end
            elseif FocusMode == "All" then
                if myRoot then
                    local wDist = (myRoot.Position - part.Position).Magnitude
                    if wDist < dist then
                        if WallCheck then
                            local params = RaycastParams.new()
                            params.FilterDescendantsInstances = {localPlayer.Character, obj}
                            params.FilterType = Enum.RaycastFilterType.Blacklist
                            local rayResult = Workspace:Raycast(camera.CFrame.Position, part.Position - camera.CFrame.Position, params)
                            if rayResult then continue end
                        end
                        dist = wDist
                        closest = part
                        CurrentTarget = obj
                    end
                end
            end
        end
    end
    return closest
end

