-- // FUNÇÃO DOWNLOADER DE FOTOS (SEM BLOQUEIO) //
local function applyBackgroundFromUrl(url, fileName)
    local req = (syn and syn.request) or request or http_request or (http and http.request)
    if not (req and getcustomasset and writefile) then 
        setFluentBackground("rbxassetid://13147607436")
        Fluent:Notify({Title="Aviso", Content="Executor não suporta download. Fundo padrão aplicado.", Duration=3})
        return 
    end
    
    Fluent:Notify({Title="Baixando Fundo", Content="Aguarde um instante...", Duration=2})
    task.spawn(function()
        local imgRes = req({Url = url, Method = "GET"})
        if imgRes.StatusCode == 200 and not string.find(string.lower(imgRes.Body), "<html") then
            writefile(fileName, imgRes.Body)
            local assetId = getcustomasset(fileName)
            setFluentBackground(assetId)
            Fluent:Notify({Title="Sucesso", Content="Fundo aplicado com sucesso!", Type="Success", Duration=3})
        else
            setFluentBackground("rbxassetid://13147607436")
            Fluent:Notify({Title="Erro", Content="Falha ao baixar. Fundo nativo aplicado.", Type="Warning", Duration=3})
        end
    end)
end

-- // INTERCEPTAÇÃO HOOK OTIMIZADA COM PREDICTION //
local gmt = getrawmetatable(game)
local oldIndex = gmt.__index
local oldNamecall = gmt.__namecall
setreadonly(gmt, false)

gmt.__index = newcclosure(function(self, index)
    if not _G.MagnetAtivado and not (IsEnabled and AimMode == "Silent Aim") then
        return oldIndex(self, index)
    end

    if not checkcaller() then
        if self == Mouse then
            if IsEnabled and AimMode == "Silent Aim" and _G.SilentTarget then
                if index == "Hit" then 
                    local aimPos = _G.SilentTarget.Position
                    if PREDICT_STRENGTH > 0 then
                        aimPos = aimPos + (_G.SilentTarget.AssemblyLinearVelocity * PREDICT_STRENGTH)
                    end
                    return CFrame.new(aimPos) 
                end
                if index == "Target" then return _G.SilentTarget end
            elseif _G.MagnetAtivado then
                if index == "Hit" then return CFrame.new(camera.CFrame.Position + (camera.CFrame.LookVector * 10000)) end
                if index == "Target" then return nil end
            end
        end
    end
    return oldIndex(self, index)
end)

gmt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    
    if not _G.MagnetAtivado and not (IsEnabled and AimMode == "Silent Aim") then
        return oldNamecall(self, ...)
    end

    local args = {...}

    if not checkcaller() then
        local caller = getcallingscript and getcallingscript()
        if caller and string.find(caller.Name, "Camera") then return oldNamecall(self, ...) end

        local redirectPos = nil
        if IsEnabled and AimMode == "Silent Aim" and _G.SilentTarget then
            redirectPos = _G.SilentTarget.Position
            if PREDICT_STRENGTH > 0 then
                redirectPos = redirectPos + (_G.SilentTarget.AssemblyLinearVelocity * PREDICT_STRENGTH)
            end
        elseif _G.MagnetAtivado then
            redirectPos = camera.CFrame.Position + (camera.CFrame.LookVector * 10000)
        end

        if redirectPos then
            if method == "Raycast" then
                local origin = args[1]
                local direction = args[2]
                local mag = direction.Magnitude
                if mag == 0 then mag = 1 end
                args[2] = (redirectPos - origin).Unit * mag
                return oldNamecall(self, unpack(args))
            elseif method == "FindPartOnRay" or method == "FindPartOnRayWithIgnoreList" or method == "FindPartOnRayWithWhitelist" then
                local ray = args[1]
                local mag = ray.Direction.Magnitude
                if mag == 0 then mag = 1 end
                args[1] = Ray.new(ray.Origin, (redirectPos - ray.Origin).Unit * mag)
                return oldNamecall(self, unpack(args))
            end
        end

        if _G.MagnetAtivado and self == UserInputService and method == "GetMouseLocation" then
            return camera.ViewportSize / 2
        end
    end

    return oldNamecall(self, ...)
end)
setreadonly(gmt, true)

-- // LÓGICA CORE AIMBOT (SISTEMA DE CORREÇÃO E VARREDURA DE NPCs) //
local cachedNPCs = {}
local lastNpcCache = 0

local function getPotentialTargets()
    local targets = {}
    
    if TargetType == "Players" or TargetType == "Ambos" then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= localPlayer and p.Character then table.insert(targets, p.Character) end
        end
    end

    if TargetType == "NPCs" or TargetType == "Ambos" then
        if tick() - lastNpcCache > 1.5 then
            cachedNPCs = {}
            
            for _, obj in ipairs(Workspace:GetChildren()) do
                if obj:IsA("Model") and obj ~= localPlayer.Character then
                    if obj:FindFirstChildOfClass("Humanoid") and not Players:GetPlayerFromCharacter(obj) then
                        table.insert(cachedNPCs, obj)
                    end
                elseif obj:IsA("Folder") or (obj:IsA("Model") and not obj:FindFirstChildOfClass("Humanoid")) then
                    local nameLower = string.lower(obj.Name)
                    if nameLower:find("enemy") or nameLower:find("enemies") or nameLower:find("npc") or nameLower:find("mob") or nameLower:find("live") or nameLower:find("bot") or nameLower:find("character") or nameLower:find("monstro") then
                        for _, subObj in ipairs(obj:GetChildren()) do
                            if subObj:IsA("Model") and subObj:FindFirstChildOfClass("Humanoid") and not Players:GetPlayerFromCharacter(subObj) then
                                table.insert(cachedNPCs, subObj)
                            end
                        end
                    end
                end
            end
            lastNpcCache = tick()
        end
        for _, npc in ipairs(cachedNPCs) do
            if npc and npc.Parent then table.insert(targets, npc) end
        end
    end
    
    return targets
end

local function getFovCenter() 
    return FovPosition == "Center" and Vector2.new(camera.ViewportSize.X / 2, (camera.ViewportSize.Y / 2) - 65) or UserInputService:GetMouseLocation() 
end

local function getCorrectPart(character)
    if not character then return nil end
    local part = character:FindFirstChild(TargetPart)
    if part and part:IsA("BasePart") then return part end
    return character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart") or character:FindFirstChildWhichIsA("BasePart")
end

local function getClosestPart()
    if not IsEnabled then CurrentTarget = nil; return nil end

    if LockMode == "LockUntilDeath" and CurrentTarget then
        local humanoid = CurrentTarget:FindFirstChildOfClass("Humanoid")
        if humanoid and humanoid.Health > 0 and CurrentTarget.Parent ~= nil then
            return getCorrectPart(CurrentTarget)
        else
            CurrentTarget = nil 
        end
    end
    
    local closest, dist = nil, math.max(FovValue, 1)
    local fovCenter = getFovCenter()
    local possibleTargets = getPotentialTargets()
    
    for _, obj in ipairs(possibleTargets) do
        local humanoid = obj:FindFirstChildOfClass("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end
        
        local isPlayer = Players:GetPlayerFromCharacter(obj)
        if TeamCheck and isPlayer and isPlayer.Team == localPlayer.Team then continue end
        
        local part = getCorrectPart(obj)
        if part then
            local pos, onScreen = camera:WorldToViewportPoint(part.Position)
            if onScreen then
                local mDist = (Vector2.new(pos.X, pos.Y) - fovCenter).Magnitude
                if mDist <= dist then
                    if WallCheck then
                        local params = RaycastParams.new()
                        params.FilterDescendantsInstances = {localPlayer.Character, obj}
                        params.FilterType = Enum.RaycastFilterType.Blacklist
                        local rayResult = Workspace:Raycast(camera.CFrame.Position, part.Position - camera.CFrame.Position, params)
                        if rayResult then continue end
                    end
                    dist = mDist
                    closest = part
                    CurrentTarget = obj
                end
            end
        end
    end
    return closest
end

-- // RENDERIZAÇÃO OTIMIZADA //
local renderConnection
renderConnection = RunService.RenderStepped:Connect(function()
    fovCircle.Size = UDim2.new(0, FovValue * 2, 0, FovValue * 2)
    magnetImgLabel.Size = UDim2.new(0, _G.MagnetSize, 0, _G.MagnetSize)
    
    if ShowFOV then
        local fovC = getFovCenter()
        fovCircle.Position = UDim2.new(0.2, fovC.X, 0, fovC.Y)
        fovCircle.Visible = true
        
        fovCircle.ImageColor3 = _G.FovColor
        fovCircle.BackgroundColor3 = _G.FovColor
        fovStroke.Color = _G.FovColor
        
        local currentFormat = _G.FovFormat
        local currentTrans = _G.FovTransparency
        
        if currentFormat == "Padrão Círculo" then
            fovCircle.BackgroundTransparency = currentTrans
            fovCircle.ImageTransparency = 1
            fovCircle.Image = ""
            fovCorner.CornerRadius = UDim.new(1, 0)
            fovStroke.Enabled = true
        else
            fovCircle.BackgroundTransparency = 1
            fovCircle.ImageTransparency = currentTrans
            fovCorner.CornerRadius = UDim.new(0, 0)
            fovStroke.Enabled = false
            if currentFormat == "Estrela" then
                fovCircle.Image = "rbxassetid://6031215981"
            elseif currentFormat == "Bola" then
                fovCircle.Image = "rbxassetid://6034289894"
            elseif currentFormat == "?" then
                fovCircle.Image = "rbxassetid://11422119106"
            end
        end
    else
        fovCircle.Visible = false
    end
    
    if _G.MagnetAtivado then
        local center = camera.ViewportSize / 2
        circleOutline.Position = center; circleInner.Position = center
        magnetImgLabel.Position = UDim2.new(0, center.X, 0, center.Y)
        magnetImgLabel.Visible = true
        circleOutline.Visible = false
        circleInner.Visible = false
    else
        magnetImgLabel.Visible = false
    end
    
    local target = getClosestPart()
    
    if IsEnabled and AimMode == "Silent Aim" and target then
        local localRoot = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
        if localRoot and (target.Position - localRoot.Position).Magnitude > _G.MaxSilentDistance then
            _G.SilentTarget = nil
        else
            _G.SilentTarget = target
        end
    else
        _G.SilentTarget = target 
    end
    
    if IsEnabled and target then
        if AimMode == "Aimbot" then
            local aimPos = target.Position
            if AimbotType == "Predict" then aimPos = aimPos + (target.AssemblyLinearVelocity * PREDICT_STRENGTH) end
            camera.CFrame = CFrame.new(camera.CFrame.Position, aimPos)
        end
        
        if LookAtEnabled and localPlayer.Character then
            local rootPart = localPlayer.Character:FindFirstChild("HumanoidRootPart")
            if rootPart then
                local lookDir = (target.Position - rootPart.Position).Unit
                rootPart.CFrame = CFrame.new(rootPart.Position, rootPart.Position + Vector3.new(lookDir.X, 0, lookDir.Z).Unit)
            end
        end
    end
    
    if target and IsEnabled then
        local tPos, onScreen = camera:WorldToViewportPoint(target.Position)
        if onScreen then
            if VisualType == "Linha" then 
                line.From = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y)
                line.To = Vector2.new(tPos.X, tPos.Y)
                line.Visible = true;
                dotVisual.Visible = false
            elseif VisualType == "Bolinha" then 
                dotVisual.Position = Vector2.new(tPos.X, tPos.Y)
                dotVisual.Visible = true;
                line.Visible = false
            else
                line.Visible = false;
                dotVisual.Visible = false
            end
        else line.Visible = false;
            dotVisual.Visible = false end
    else line.Visible = false;
        dotVisual.Visible = false end
end)

