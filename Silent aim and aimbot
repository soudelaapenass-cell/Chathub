local function toggleScreenEditor(state)
    ScreenEditor.Enabled = state
    GlobalPanel.Visible = state
    if not state then
        ContextMenu.Visible = false; ScreenEditor.SelectedObject = nil
        for _, conn in pairs(ScreenEditor.Connections) do conn:Disconnect() end
        ScreenEditor.Connections = {}
    else
        for _, child in pairs(localPlayer.PlayerGui:GetDescendants()) do
            if (child:IsA("TextButton") or child:IsA("ImageButton")) then
                if not child:IsDescendantOf(toggleGui) and not child:IsDescendantOf(EditorGui) then
                    saveOriginalState(child)
                    local conns = makeDraggable(child, function() return ScreenEditor.Enabled end)
                    for _, c in ipairs(conns) do table.insert(ScreenEditor.Connections, c) end
                end
            end
        end
    end
end

