local function makeDraggable(obj, conditionFunc)
    local dragging, dragStart, startPos
    local c1 = obj.InputBegan:Connect(function(input)
        if conditionFunc() and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            dragging = true; dragStart = input.Position; startPos = obj.Position
            if obj ~= magnetImgLabel and obj ~= PreviewFrame then
                ScreenEditor.SelectedObject = obj
                ContextMenu.Position = UDim2.new(0, math.clamp(obj.AbsolutePosition.X, 10, camera.ViewportSize.X - 170), 0, math.clamp(obj.AbsolutePosition.Y - 50, 10, camera.ViewportSize.Y - 50))
                ContextMenu.Visible = true
            end
        end
    end)
    local c2 = obj.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
    local c3 = UserInputService.InputChanged:Connect(function(input)
        if dragging and conditionFunc() and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + (input.Position - dragStart).X, startPos.Y.Scale, startPos.Y.Offset + (input.Position - dragStart).Y)
        end
    end)
    return {c1, c2, c3}
end

makeDraggable(magnetImgLabel, function() return ScreenEditor.MagnetMovable end)
