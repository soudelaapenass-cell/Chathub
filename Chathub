    sBtn.Size = UDim2.new(1, -10, 0, 35)
    sBtn.Text = "  " .. sData.name
    sBtn.TextXAlignment = Enum.TextXAlignment.Left
    sBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    sBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    sBtn.ZIndex = 51
    Instance.new("UICorner", sBtn).CornerRadius = UDim.new(0, 8)
    
    local execS = Instance.new("TextButton", sBtn)
    execS.Size = UDim2.new(0, 30, 0, 30)
    execS.Position = UDim2.new(1, -35, 0, 2)
    execS.Text = "▶"
    execS.BackgroundColor3 = Color3.fromRGB(0, 180, 80)
    execS.TextColor3 = Color3.fromRGB(255, 255, 255)
    execS.Visible = false
    execS.ZIndex = 51
    Instance.new("UICorner", execS).CornerRadius = UDim.new(1, 0)
    
    sBtn.MouseButton1Click:Connect(function()
        for _, v in pairs(ScriptScroll:GetChildren()) do
            if v:IsA("TextButton") and v:FindFirstChild("TextButton") then 
                v.TextButton.Visible = false 
            end
        end
        execS.Visible = true
    end)
    
    execS.MouseButton1Click:Connect(function()
        local func = loadstring(sData.code)
        if type(func) == "function" then task.spawn(func) end
    end)
end
