local function getPartFromPrompt(prompt)
    if not prompt or not prompt.Parent then return nil end
    if prompt.Parent:IsA("BasePart") then return prompt.Parent end
    return prompt.Parent:FindFirstChildWhichIsA("BasePart", true)
end

local function handleDroppedItems()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Tool") and not isHeld(obj) then
            local handle = obj:FindFirstChild("Handle") or obj:FindFirstChildWhichIsA("BasePart")
            if handle and not handle:FindFirstChildOfClass("ProximityPrompt") then
                local prompt = Instance.new("ProximityPrompt")
                prompt.ActionText = "Pegar"
                prompt.ObjectText = obj.Name
                prompt.HoldDuration = 0
                prompt.MaxActivationDistance = 20
                prompt.RequiresLineOfSight = false
                prompt.Parent = handle
            end
        end
    end
end

local function getInteractables()
    local list = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if isHeld(obj) then continue end

        if obj:IsA("ProximityPrompt") then
            local p = getPartFromPrompt(obj)
            if p then
                table.insert(list, {
                    id = obj,
                    part = p,
                    name = obj.ObjectText ~= "" and obj.ObjectText or (obj.Parent and obj.Parent.Name or "Item"),
                    type = "Prompt"
                })
            end
        elseif obj:IsA("ClickDetector") then
            local p = obj.Parent
            if p and p:IsA("BasePart") then
                table.insert(list, {
                    id = obj,
                    part = p,
                    name = p.Name,
                    type = "Click"
                })
            end
        elseif obj:IsA("TouchTransmitter") then
            local p = obj.Parent
            if p and p:IsA("BasePart") and p.Size.Magnitude <= 15 then
                if not p:FindFirstChildOfClass("ProximityPrompt") and not p:FindFirstChildOfClass("ClickDetector") then
                    table.insert(list, {
                        id = p,
                        part = p,
                        name = p.Name .. " [Tocar]",
                        type = "Touch"
                    })
                end
            end
        end
    end
    return list
