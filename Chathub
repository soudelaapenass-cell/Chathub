local function CreateESP(target, isPlayer)
    if isPlayer and target == LocalPlayer then return end

    local function CharacterAdded(char)
        local head = char:WaitForChild("Head", 5)
        local hum = char:WaitForChild("Humanoid", 5)
        if not head or not hum then return end

        hum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None

        local bbg = Instance.new("BillboardGui")
        bbg.Name = "LEZIN_ESP_UI"
        bbg.Adornee = head
        bbg.Size = UDim2.new(0, 150, 0, 160)
        bbg.StudsOffset = Vector3.new(0, 0.5, 0)
        bbg.AlwaysOnTop = true
        bbg.Parent = head

        local container = Instance.new("Frame", bbg)
        container.Size = UDim2.new(1, 0, 1, 0)
        container.BackgroundTransparency = 1

        local icon = Instance.new("ImageLabel", container)
        icon.Size = UDim2.new(0, 40, 0, 40)
        icon.Position = UDim2.new(0.5, -20, 0, 0)
        icon.BackgroundTransparency = 1 
        icon.BorderSizePixel = 0
        if isPlayer then
            icon.Image = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. target.UserId .. "&width=420&height=420&format=png"
        else
            icon.Visible = false
        end

        local nameLabel = Instance.new("TextLabel", container)
        nameLabel.Size = UDim2.new(1, 0, 0, 20)
        nameLabel.Position = UDim2.new(0, 0, 0, 45)
        nameLabel.BackgroundTransparency = 1
        nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        nameLabel.TextStrokeTransparency = 0.5
        nameLabel.Font = Enum.Font.SourceSansBold
        nameLabel.TextSize = 16
        nameLabel.TextXAlignment = Enum.TextXAlignment.Center
        nameLabel.TextTransparency = 1

        local healthBack = Instance.new("Frame", container)
        healthBack.Size = UDim2.new(0, 100, 0, 6)
        healthBack.Position = UDim2.new(0.5, -50, 0, 70)
        healthBack.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        healthBack.BorderSizePixel = 0

        local healthBar = Instance.new("Frame", healthBack)
        healthBar.Size = UDim2.new(1, 0, 1, 0)
        healthBar.Position = UDim2.new(0, 0, 0, 0)
        healthBar.BorderSizePixel = 0

        local healthText = Instance.new("TextLabel", healthBack)
        healthText.Size = UDim2.new(1, 0, 0, 15)
        healthText.Position = UDim2.new(0, 0, 0, -15)
        healthText.BackgroundTransparency = 1
        healthText.TextColor3 = Color3.fromRGB(255, 255, 255)
        healthText.Font = Enum.Font.SourceSansBold
        healthText.TextSize = 12
        healthText.TextStrokeTransparency = 0.5

        local itemContainer = Instance.new("Frame", container)
        itemContainer.Size = UDim2.new(0, 150, 0, 80)
        itemContainer.Position = UDim2.new(0, 0, 0, 80)
        itemContainer.BackgroundTransparency = 1

        local highlight = Instance.new("Highlight")
        highlight.Adornee = char
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Parent = char

        local currentFade = 1
        local smoothHp = hum.Health / hum.MaxHealth
        
        local conn
        conn = RunService.RenderStepped:Connect(function()
            if not char or not char.Parent or not hum then 
                currentFade = math.min(currentFade + 0.05, 1)
                nameLabel.TextTransparency = currentFade
                if currentFade >= 1 then conn:Disconnect(); bbg:Destroy(); highlight:Destroy() end
                return 
            end

            local targetAllowed = false
            if isPlayer and (_G_Config.TargetMode == "Players" or _G_Config.TargetMode == "Both") then
                targetAllowed = true
            elseif not isPlayer and (_G_Config.TargetMode == "Mobs" or _G_Config.TargetMode == "Both") then
                targetAllowed = true
            end

            local isAlly = isPlayer and (_G_Config.TeamCheck and target.Team == LocalPlayer.Team)
            local canShow = not isAlly and targetAllowed and (_G_Config.ChamsEnabled or _G_Config.NameEnabled or _G_Config.IconEnabled or _G_Config.HealthEnabled or _G_Config.HeldItemEnabled or _G_Config.InventoryEnabled)
            local isDead = (hum.Health <= 0)

            bbg.Enabled = canShow
            highlight.Enabled = canShow and _G_Config.ChamsEnabled and not isDead
            icon.Visible = isPlayer and _G_Config.IconEnabled and not isDead
            healthBack.Visible = _G_Config.HealthEnabled and not isDead

            itemContainer:ClearAllChildren()
            
            if not isDead and (_G_Config.HeldItemEnabled or _G_Config.InventoryEnabled) then
                local itemsToShow = {}
                if _G_Config.HeldItemEnabled then
                    local t = char:FindFirstChildOfClass("Tool")
                    if t then table.insert(itemsToShow, t) end
                end
                if isPlayer and _G_Config.InventoryEnabled and target:FindFirstChild("Backpack") then
                    for _, i in pairs(target.Backpack:GetChildren()) do if i:IsA("Tool") then table.insert(itemsToShow, i) end end
                end

                for i, tool in pairs(itemsToShow) do
                    if i > 3 then break end
                    local frame = Instance.new("Frame", itemContainer)
                    frame.Size = UDim2.new(0, 140, 0, 20)
                    frame.Position = UDim2.new(0, 5, 0, (i-1)*22)
                    frame.BackgroundTransparency = 1
                    
                    local img = Instance.new("ImageLabel", frame)
                    img.Size = UDim2.new(0, 20, 0, 20)
                    img.BackgroundTransparency = 1
                    img.Image = (tool.TextureId ~= "" and tool.TextureId) or "rbxassetid://0"
                    
                    local txt = Instance.new("TextLabel", frame)
                    txt.Size = UDim2.new(0, 110, 0, 20)
                    txt.Position = UDim2.new(0, 25, 0, 0)
                    txt.BackgroundTransparency = 1
                    txt.Text = tool.Name
                    txt.TextColor3 = Color3.fromRGB(255, 255, 255)
                    txt.TextXAlignment = Enum.TextXAlignment.Left
                    txt.TextSize = 12
                end
            end

            if isDead then
                nameLabel.Text = "KILL!"
                nameLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
                nameLabel.Visible = true
                currentFade = math.max(currentFade - 0.05, 0)
                nameLabel.TextTransparency = currentFade
            else
                nameLabel.Text = isPlayer and (target.DisplayName or target.Name) or char.Name
                nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                nameLabel.Visible = _G_Config.NameEnabled
                currentFade = math.max(currentFade - 0.05, 0)
                nameLabel.TextTransparency = currentFade
            end

            if not isDead then
                local targetHp = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                smoothHp = smoothHp + (targetHp - smoothHp) * 0.1
                healthBar.Size = UDim2.new(smoothHp, 0, 1, 0)
                healthText.Text = math.floor(smoothHp * 100) .. "%"
                healthBar.BackgroundColor3 = smoothHp > 0.6 and Color3.fromRGB(0, 255, 0) or (smoothHp > 0.25 and Color3.fromRGB(255, 165, 0) or Color3.fromRGB(255, 0, 0))
            end
            highlight.FillColor = isPlayer and target.TeamColor.Color or Color3.fromRGB(255, 0, 0)
        end)
    end

    if isPlayer then
        target.CharacterAdded:Connect(CharacterAdded)
        if target.Character then CharacterAdded(target.Character) end
    else
        CharacterAdded(target)
    end
end

