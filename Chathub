local btnDrag, btnStart, btnPos
ToggleBtn.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        btnDrag = true
        btnStart = i.Position
        btnPos = ToggleBtn.Position
    end
end)

UserInputService.InputChanged:Connect(function(i)
    if btnDrag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
        local delta = i.Position - btnStart
        ToggleBtn.Position = UDim2.new(btnPos.X.Scale, btnPos.X.Offset + delta.X, btnPos.Y.Scale, btnPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        btnDrag = false
    end
end)

local drag, dStart, sPos
DragBar.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        drag = true
        dStart = i.Position
        sPos = MainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(i)
    if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
        local delta = i.Position - dStart
        MainFrame.Position = UDim2.new(sPos.X.Scale, sPos.X.Offset + delta.X, sPos.Y.Scale, sPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function()
    if drag then
        drag = false
        lastMainPos = MainFrame.Position
    end
end)

-- --- CHAT E EXECUÇÃO ---
local function addMessage(name, userId, text)
    local Frame = Instance.new("Frame", ScrollingFrame)
    Frame.Size = UDim2.new(1, -10, 0, 45)
    Frame.BackgroundTransparency = 1
    Frame.ZIndex = 11

    local Img = Instance.new("ImageLabel", Frame)
    Img.Size = UDim2.new(0, 35, 0, 35)
    Img.Image = "rbxthumb://type=AvatarHeadShot&id="..userId.."&w=150&h=150"
    Img.ZIndex = 12
    Instance.new("UICorner", Img).CornerRadius = UDim.new(1,0)

    local LblBtn = Instance.new("TextButton", Frame)
    LblBtn.Size = UDim2.new(1, -45, 1, 0)
    LblBtn.Position = UDim2.new(0, 45, 0, 0)
    LblBtn.ZIndex = 12
    LblBtn.Text = "<b>"..name.."</b>: "..text
    LblBtn.RichText = true
    LblBtn.TextColor3 = Color3.fromRGB(255,255,255)
    LblBtn.BackgroundTransparency = 1
    LblBtn.TextXAlignment = Enum.TextXAlignment.Left
    LblBtn.TextWrapped = true
    
    LblBtn.MouseButton1Click:Connect(function()
        InputBox.Text = "/w " .. name .. " "
        InputBox:CaptureFocus()
    end)

    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIList.AbsoluteContentSize.Y)
    if autoScrollEnabled then
        ScrollingFrame.CanvasPosition = Vector2.new(0, UIList.AbsoluteContentSize.Y)
    end
end

ExecBtn.MouseButton1Click:Connect(function()
    local code = InputBox.Text
    if code == "" then
        code = SecTextBox.Text
    end
    local func = loadstring(code)
    if type(func) == "function" then
        setfenv(func, getfenv(0))
        task.spawn(func)
    end
end)

ChatBtn.MouseButton1Click:Connect(function()
    if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
        TextChatService.TextChannels.RBXGeneral:SendAsync(InputBox.Text)
    else
        game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(InputBox.Text, "All")
    end
end)

ScrollToggle.MouseButton1Click:Connect(function()
    autoScrollEnabled = not autoScrollEnabled
    ScrollToggle.Text = autoScrollEnabled and Langs[currentLang].scrollOn or Langs[currentLang].scrollOff
    ScrollToggle.BackgroundColor3 = autoScrollEnabled and Color3.fromRGB(0, 180, 255) or Color3.fromRGB(80,80,80)
end)

if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
    TextChatService.OnIncomingMessage = function(m)
        if m.TextSource then
            local p = Players:GetPlayerByUserId(m.TextSource.UserId)
            if p then
                addMessage(p.DisplayName, p.UserId, m.Text)
            end
        end
    end
else
    local events = game:GetService("ReplicatedStorage"):WaitForChild("DefaultChatSystemChatEvents", 5)
    if events then
        events.OnMessageDoneFiltering.OnClientEvent:Connect(function(d)
            local p = Players:FindFirstChild(d.FromSpeaker)
            if p then
                addMessage(p.DisplayName, p.UserId, d.Message)
            end
        end)
    end
end

