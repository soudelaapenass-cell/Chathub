-- Variáveis de estado
local isHubOpen = false
local lastDroppedItem = nil
local autoSwitchActive = false

-- ==========================================
-- BOTÃO FLUTUANTE
-- ==========================================
local FloatingButton = Instance.new("ImageButton")
FloatingButton.Size = UDim2.new(0, 60, 0, 60)
FloatingButton.Position = UDim2.new(0, 50, 0.5, 0)
FloatingButton.Image = "rbxassetid://75012424452065"
FloatingButton.BackgroundTransparency = 1
FloatingButton.Parent = ScreenGui

local FloatingText = Instance.new("TextLabel", FloatingButton)
FloatingText.Text = "by Lezin"; FloatingText.Position = UDim2.new(0, 0, 0, -20); FloatingText.Size = UDim2.new(1, 0, 0, 20)
