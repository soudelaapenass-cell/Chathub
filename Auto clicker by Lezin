-- Sistema Principal de Auto Clicker (COM TOQUE MOBILE)
task.spawn(function()
    while true do
        if isAutoClicking then
            clickSpeed = tonumber(SpeedBox.Text) or 0.1
            
            -- Pega a margem da tela (corrige o bug do toque fora da bolinha)
            local inset = GuiService:GetGuiInset()
            
            -- PASSO 1: Envia evento de Dedo Pressionando (TouchDown)
            for i, ball in ipairs(targetBalls) do
                if ball and ball.Parent then
                    -- Calcula o meio exato do pontinho vermelho somando a margem da tela
                    local clickX = ball.AbsolutePosition.X + (ball.AbsoluteSize.X / 2) + inset.X
                    local clickY = ball.AbsolutePosition.Y + (ball.AbsoluteSize.Y / 2) + inset.Y
                    
                    local touchId = 1500 + i -- ID único de toque pro Roblox não se confundir
                    
                    -- Simula o Toque! (0 = Dedo Tocou na tela)
                    VirtualInputManager:SendTouchEvent(touchId, 0, clickX, clickY)
                end
            end
            
            task.wait(0.01) -- Pequeno delay pro botão do jogo registrar que afundou
            
            -- PASSO 2: Envia evento de Dedo Soltando (TouchUp)
            for i, ball in ipairs(targetBalls) do
                if ball and ball.Parent then
                    local clickX = ball.AbsolutePosition.X + (ball.AbsoluteSize.X / 2) + inset.X
                    local clickY = ball.AbsolutePosition.Y + (ball.AbsoluteSize.Y / 2) + inset.Y
                    
                    local touchId = 1500 + i
                    
                    -- Simula soltar o dedo! (2 = Dedo saiu da tela)
                    VirtualInputManager:SendTouchEvent(touchId, 2, clickX, clickY)
                end
            end

            task.wait(clickSpeed)
        else
            task.wait(0.1)
        end
    end
end)
