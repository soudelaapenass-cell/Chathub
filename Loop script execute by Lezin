TabHolder.Size = UDim2.new(0, 85, 1, -70)
TabHolder.BackgroundTransparency = 1
Instance.new("UIListLayout", TabHolder).Padding = UDim.new(0, 5)

local activeLoops = {}
function CreateTab(i)
    local bt = Instance.new("TextButton", TabHolder)
    bt.Size = UDim2.new(1, 0, 0, 32)
    bt.Text = "Aba "..i
    bt.BackgroundColor3 = Color3.new(0,0,0)
    bt.BackgroundTransparency = 0.5
    bt.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", bt)

    local pg = Instance.new("Frame", PageHolder)
    pg.Size = UDim2.new(1, 0, 1, 0)
    pg.Visible = (i == 1)
    pg.BackgroundTransparency = 1

    local txt = Instance.new("TextBox", pg)
    txt.Size = UDim2.new(1, 0, 0.5, 0)
    txt.MultiLine = true
    txt.PlaceholderText = "Cole o script..."
    txt.BackgroundTransparency = 0.7
    txt.TextColor3 = Color3.new(0,1,0)
    Instance.new("UICorner", txt)

    local spd = Instance.new("TextBox", pg)
    spd.Size = UDim2.new(1, 0, 0.15, 0)
    spd.Position = UDim2.new(0, 0, 0.55, 0)
    spd.Text = "0.5"
    spd.BackgroundTransparency = 0.7
    spd.TextColor3 = Color3.new(1,1,1)

    local go = Instance.new("TextButton", pg)
    go.Size = UDim2.new(1, 0, 0.2, 0)
    go.Position = UDim2.new(0, 0, 0.75, 0)
    go.Text = "LIGAR"
    go.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    Instance.new("UICorner", go)

    bt.MouseButton1Click:Connect(function()
        for _, v in pairs(PageHolder:GetChildren()) do v.Visible = false end
        pg.Visible = true
    end)

    activeLoops[i] = false
    go.MouseButton1Click:Connect(function()
        activeLoops[i] = not activeLoops[i]
        SoundInt:Play()
        if activeLoops[i] then
            go.Text = "DESLIGAR"
            go.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
            task.spawn(function()
                while activeLoops[i] do
                    ExecutarScript(txt.Text) -- Chama a função universal
                    task.wait(tonumber(spd.Text) or 0.5)
                end
            end)
        else
            go.Text = "LIGAR"
            go.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        end
    end)
end
for i=1, 10 do CreateTab(i) end
