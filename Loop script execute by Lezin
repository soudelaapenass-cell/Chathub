-- Alternar Menu
local isOpened = true
local function toggle()
    isOpened = not isOpened
    SoundInt:Play()
    if isOpened then
        Content.Visible = true
        MainFrame:TweenSizeAndPosition(UDim2.new(0, 500, 0, 350), UDim2.new(0.5, -250, 0.5, -175), "Out", "Back", 0.4, true)
        MainFrame.Image = "rbxassetid://126966972982411"
        if BGM.SoundId ~= "" then BGM:Play() end
    else
        Content.Visible = false
        SetPanel.Visible = false
        MainFrame:TweenSizeAndPosition(UDim2.new(0, 75, 0, 75), UDim2.new(0.1, 0, 0.1, 0), "Out", "Back", 0.4, true)
        MainFrame.Image = "rbxassetid://97871211303571"
        BGM:Pause()
    end
end
CloseBtn.MouseButton1Click:Connect(toggle)

-- Drag System
local dragging, dragStart, startPos, moveAmount = false, nil, nil, 0
MainFrame.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        dragging = true dragStart = input.Position startPos = MainFrame.Position moveAmount = 0
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        moveAmount = moveAmount + delta.Magnitude
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(input)
    if dragging then dragging = false if not isOpened and moveAmount < 10 then toggle() end end
end)

-- EXECUÇÃO UNIVERSAL (Funciona com RemoteSpy e outros)
local function ExecutarScript(codigo)
    local func, err = loadstring(codigo)
    if func then
        -- Define o ambiente para o global do executor (getgenv)
        setfenv(func, getfenv(0)) 
        task.spawn(func)
    else
        warn("Erro no Script: " .. tostring(err))
    end
end

-- Sistema de Abas
local PageHolder = Instance.new("Frame", Content)
PageHolder.Position = UDim2.new(0, 105, 0, 55)
