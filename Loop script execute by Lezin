-- Créditos na Cabeça
local function MostrarCreditos()
    pcall(function()
        local player = game.Players.LocalPlayer
        local char = player.Character or player.CharacterAdded:Wait()
        local head = char:WaitForChild("Head")
        local bbg = Instance.new("BillboardGui", head)
        bbg.Size = UDim2.new(0, 250, 0, 50)
        bbg.Adornee = head
        bbg.ExtentsOffset = Vector3.new(0, 3, 0)
        bbg.AlwaysOnTop = true
        local lbl = Instance.new("TextLabel", bbg)
        lbl.Size = UDim2.new(1, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = "Script by Lezin e Gemini 🥰"
        lbl.TextColor3 = Color3.new(1, 1, 1)
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 22
        lbl.TextStrokeTransparency = 0
        task.spawn(function()
            local t = 0
            while bbg.Parent do
                lbl.TextStrokeColor3 = Color3.fromHSV(t, 1, 1)
                t = (t + 0.01) % 1
                task.wait()
            end
        end)
        task.wait(5)
        TweenService:Create(lbl, TweenInfo.new(1.5), {TextTransparency = 1, TextStrokeTransparency = 1}):Play()
        task.wait(1.5)
        bbg:Destroy()
    end)
end
MostrarCreditos()

