local function HandleMovementControl(vec)
    local now = tick()
    -- Lógica de duplo clique (menos de 0.3 segundos)
    if now - LastClickTime < 0.3 then
        if MoveMode == "Move" then 
            MoveMode = "Rotate"
            ModeIndicator.Text = "Modo Atual: GIRAR"
            ModeIndicator.TextColor3 = Color3.fromRGB(255, 150, 0)
        else 
            MoveMode = "Move"
            ModeIndicator.Text = "Modo Atual: MOVER"
            ModeIndicator.TextColor3 = Color3.fromRGB(0, 255, 0)
        end
    else
        -- Lógica de ação
        if SelectedPart then
            if MoveMode == "Move" then
                SelectedPart.CFrame = SelectedPart.CFrame + vec
            else
                SelectedPart.CFrame = SelectedPart.CFrame * CFrame.Angles(
                    math.rad(vec.X * 15), 
                    math.rad(vec.Y * 15), 
                    math.rad(vec.Z * 15)
                )
            end
        end
    end
    LastClickTime = now
end

for _, d in ipairs(dirs) do
