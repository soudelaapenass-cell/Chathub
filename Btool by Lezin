-- 4. Sliders (Transparência e Tamanho)
local function createSlider(name, minVal, maxVal, pos, parent)
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0.9, 0, 0, 20)
    Label.Position = pos
    Label.BackgroundTransparency = 1
    Label.TextColor3 = Color3.fromRGB(200, 200, 200)
    Label.Font = Enum.Font.Gotham
    Label.TextSize = 12
    Label.Text = name .. " (" .. minVal .. " - " .. maxVal .. ")"
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = parent

    local Bg = Instance.new("Frame")
    Bg.Size = UDim2.new(0.9, 0, 0, 10)
    Bg.Position = pos + UDim2.new(0, 0, 0, 25)
    Bg.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Bg.Parent = parent
    
    local Fill = Instance.new("Frame")
    Fill.Size = UDim2.new(0.5, 0, 1, 0)
    Fill.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
    Fill.Parent = Bg

    local Button = Instance.new("TextButton")
    Button.Size = UDim2.new(1, 0, 1, 0)
    Button.BackgroundTransparency = 1
    Button.Text = ""
    Button.Parent = Bg

    return Button, Fill, Bg
end

local TranspBtn, TranspFill, TranspBg = createSlider("Transparência", 0, 1, UDim2.new(0.05, 0, 0.2, 0), MainFrame)
local SizeBtn, SizeFill, SizeBg = createSlider("Tamanho", 1, 950, UDim2.new(0.05, 0, 0.32, 0), MainFrame)

local draggingTransp = false
local draggingSize = false

-- Fix para toques em Mobile e Mouse
TranspBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingTransp = true
    end
end)

SizeBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingSize = true
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingTransp = false
        draggingSize = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        if SelectedPart then
            local inputPos = input.Position.X
            
            if draggingTransp then
                local pct = math.clamp((inputPos - TranspBg.AbsolutePosition.X) / TranspBg.AbsoluteSize.X, 0, 1)
                TranspFill.Size = UDim2.new(pct, 0, 1, 0)
                SelectedPart.Transparency = pct
                
                -- Altera a transparência real de Decals e Texturas anexadas à parte
                for _, child in pairs(SelectedPart:GetChildren()) do
                    if child:IsA("Decal") or child:IsA("Texture") then
                        child.Transparency = pct
                    end
                end
            end
            
            if draggingSize then
                local pct = math.clamp((inputPos - SizeBg.AbsolutePosition.X) / SizeBg.AbsoluteSize.X, 0, 1)
                SizeFill.Size = UDim2.new(pct, 0, 1, 0)
                local newSize = 1 + (pct * 949)
                SelectedPart.Size = Vector3.new(newSize, newSize, newSize)
            end
        end
    end
end)

