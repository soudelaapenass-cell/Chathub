-- 7. Botão Redefinir (Reset)
local BtnReset = createButton("Redefinir Tudo (Reset)", UDim2.new(0.05, 0, 0.88, 0), UDim2.new(0.9, 0, 0, 35), MainFrame)
BtnReset.BackgroundColor3 = Color3.fromRGB(100, 100, 100)

BtnReset.MouseButton1Click:Connect(function()
    if SelectedPart and OriginalStates[SelectedPart] then
        local state = OriginalStates[SelectedPart]
        SelectedPart.Size = state.Size
        SelectedPart.Transparency = state.Transparency
        SelectedPart.BrickColor = state.BrickColor
        SelectedPart.CFrame = state.CFrame
        SelectedPart.CanCollide = state.CanCollide
        
        -- Atualiza as texturas de volta
        for _, child in pairs(SelectedPart:GetChildren()) do
            if child:IsA("Decal") or child:IsA("Texture") then
                child.Transparency = state.Transparency
            end
        end
        
        -- Atualiza os sliders visuais para corresponder
        TranspFill.Size = UDim2.new(state.Transparency, 0, 1, 0)
        local pctSize = math.clamp((state.Size.X - 1) / 949, 0, 1)
        SizeFill.Size = UDim2.new(pctSize, 0, 1, 0)
    end
end)

-- 8. Lógica da Ferramenta e Mouse
local Equipped = false

Tool.Equipped:Connect(function()
    Equipped = true
end)

Tool.Unequipped:Connect(function()
    Equipped = false
    MainFrame.Visible = false
    SelectionBox.Adornee = nil
    SelectedPart = nil
end)

Mouse.Button1Down:Connect(function()
    if Equipped and Mouse.Target and not draggingTransp and not draggingSize then
        local target = Mouse.Target
        
        -- Ignora se clicar na própria UI
        if target:IsDescendantOf(ScreenGui) then return end
        
        SelectedPart = target
        SelectionBox.Adornee = SelectedPart
        MainFrame.Visible = true
        
        -- Salvar o estado original se for a primeira vez
        if not OriginalStates[SelectedPart] then
            OriginalStates[SelectedPart] = {
                Size = SelectedPart.Size,
                Transparency = SelectedPart.Transparency,
                BrickColor = SelectedPart.BrickColor,
                CFrame = SelectedPart.CFrame,
                CanCollide = SelectedPart.CanCollide
            }
        end
        
        -- Ajustar visual dos sliders para a peça atual
        TranspFill.Size = UDim2.new(SelectedPart.Transparency, 0, 1, 0)
        local currentSizePct = math.clamp((SelectedPart.Size.X - 1) / 949, 0, 1)
        SizeFill.Size = UDim2.new(currentSizePct, 0, 1, 0)
    end
end)
